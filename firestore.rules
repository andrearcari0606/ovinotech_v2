rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /usuarios/{userId} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;
    }

    match /usuarios/{userId}/rebanho/{animalId} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;
    }

    match /usuarios/{userId}/pesagens/{pesagemId} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;
    }

    match /usuarios/{userId}/manejos/{manejoId} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;
    }

    match /usuarios/{userId}/reproducao/{reproducaoId} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;
    }
  }
}